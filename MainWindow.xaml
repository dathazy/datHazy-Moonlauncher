<Window x:Class="datHazy_Moonlauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="datHazy Moonlauncher"
        Height="500"
        Width="800"
        Background="#121212"
        Icon="pack://application:,,,/Assets/moonlauncher.ico">

    <Grid>

        <!-- MAIN CONTENT -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <Grid>
                <StackPanel x:Name="Root"
                            Margin="20"
                            HorizontalAlignment="Center">

                    <TextBlock x:Name="StatusText"
                               Text="Loading..."
                               Foreground="White"
                               FontSize="20"
                               Margin="0,0,0,20"/>

                </StackPanel>
            </Grid>

        </ScrollViewer>

        <!-- LOADING OVERLAY -->
        <Grid x:Name="LoadingOverlay"
              Background="#AA000000"
              Visibility="Collapsed">

            <Border Background="#15151A"
                    Padding="28"
                    CornerRadius="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#2A2A30"
                    BorderThickness="1">

                <StackPanel Width="260">

                    <TextBlock x:Name="LoadingTitle"
                               Text="Processing..."
                               Foreground="White"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>

                    <ProgressBar Height="6"
                                 IsIndeterminate="True"/>

                </StackPanel>

            </Border>

        </Grid>

        <!-- FLOATING PATH BUTTON -->
        <Button x:Name="FloatingPathButton"
                Content="Set Moonlight Path"
                Width="170"
                Height="38"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,20"
                Visibility="Collapsed"/>

    </Grid>

</Window>